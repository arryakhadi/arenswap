# Public WalletConnect/Reown project ID. Required for mobile wallet connection.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Circle App Kit / Kit Key - server-only, never exposed to the browser.
# Used by the /api/circle/swap proxy route to call Circle's Stablecoin Service.
CIRCLE_KIT_KEY=KIT_KEY:your_circle_kit_key
